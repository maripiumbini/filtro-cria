    <section class="mb-16">
        <div class="card p-8 md:p-16 relative overflow-hidden bg-white text-center">
            <h2 class="text-3xl font-georgia mb-8 text-[#2b2b2b]">O que vamos monitorizar agora?</h2>
            
            <div class="max-w-3xl mx-auto flex flex-col md:flex-row gap-2">
                <input type="text" id="topicInput" placeholder="Nicho, Marca ou Tecnologia (ex: IA no Varejo)" 
                    class="flex-1 p-5 border-2 border-[#2b2b2b] outline-none focus:bg-white bg-[#fff8f5] text-lg font-fira">
