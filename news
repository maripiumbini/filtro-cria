<script>
// A apiKey é injetada automaticamente pelo ambiente Vercel/Preview
const apiKey = ""; 

async function fetchWithRetry(url, options, maxRetries = 5) {
    let delay = 1000;
    for (let i = 0; i < maxRetries; i++) {
        try {
            const response = await fetch(url, options);
            if (response.ok) return await response.json();
        } catch (err) { if (i === maxRetries - 1) throw err; }
        await new Promise(res => setTimeout(res, delay));
        delay *= 2;
    }
}

async function startAutomaticScan() {
    const input = document.getElementById('topicInput').value.trim();
    if (!input) return;

    const loader = document.getElementById('loaderArea');
    const results = document.getElementById('resultsArea');
    const standby = document.getElementById('standbyArea');
    const btn = document.getElementById('scanBtn');

    loader.classList.remove('hidden');
    results.classList.add('hidden');
    standby.classList.add('hidden');
    btn.disabled = true;

    try {
        const systemPrompt = `Você é Mariana Piumbini, analista de tendências de elite. 
        Sua missão é usar obrigatoriamente a ferramenta Google Search para encontrar as notícias mais quentes de hoje sobre o tópico solicitado.
        Formate a saída rigorosamente como JSON:
        {
          "volume": 85,
          "tags": ["keyword1", "keyword2", "keyword3"],
          "noticias": [
            {
              "titulo": "manchete real encontrada",
              "veiculo": "fonte",
              "data": "hoje",
              "url": "link real",
              "insight": "breve análise C.R.I.A.",
              "hook": "um gancho de post viral para LinkedIn"
            }
          ]
        }`;

        const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
        const response = await fetchWithRetry(url, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                contents: [{ parts: [{ text: `Pesquisa notícias e tendências de agora sobre: ${input}` }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] },
                tools: [{ "google_search": {} }],
                generationConfig: { responseMimeType: "application/json", temperature: 0.7 }
            })
        });

        const data = JSON.parse(response.candidates[0].content.parts[0].text);
        renderContent(data);
        
        loader.classList.add('hidden');
        results.classList.remove('hidden');
    } catch (e) {
        console.error(e);
        standby.innerHTML = `<p class="text-red-500 font-bold uppercase">Erro na Conexão. Verifique sua chave de API.</p>`;
        standby.classList.remove('hidden');
        loader.classList.add('hidden');
    }
    btn.disabled = false;
}

function renderContent(data) {
    // Volume Trend
    document.getElementById('trendValue').innerText = data.volume + "%";
    document.getElementById('trendBar').style.width = data.volume + "%";

    // Tags
    const tagsArea = document.getElementById('keywordsArea');
    tagsArea.innerHTML = data.tags.map(t => `<span class="bg-azul/10 text-azul border border-azul/30 px-4 py-2 text-[10px] font-bold uppercase tracking-widest">#${t}</span>`).join('');

    // Grid
    const grid = document.getElementById('newsGrid');
    grid.innerHTML = data.noticias.map(n => `
        <div class="news-card p-8 flex flex-col bg-white">
            <div class="flex justify-between items-start mb-6">
                <span class="text-[10px] font-bold text-azul uppercase tracking-[0.2em]">${n.veiculo}</span>
                <span class="text-[10px] text-gray-300 font-fira">${n.data}</span>
            </div>
            <h4 class="text-xl font-bold mb-6 font-georgia leading-tight text-vinho">${n.titulo}</h4>
            
            <div class="hook-box mb-6">
                <span class="hook-label">HOOK ESTRATÉGICO</span>
                <p class="text-[12px] text-gray-800 italic leading-relaxed font-georgia">"${n.hook}"</p>
            </div>
            
            <p class="text-[11px] text-gray-500 mb-8 leading-relaxed">${n.insight}</p>
            
            <a href="${n.url}" target="_blank" class="mt-auto text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:text-vinho transition-colors">
                Ver Fonte Original →
            </a>
        </div>
    `).join('');
}
</script>

